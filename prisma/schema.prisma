generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth & User Management
model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  email       String   @unique
  fullName    String?
  role        Role     @default(USER)
  status      UserStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profiles")
}

model AccessRequest {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  fullName    String?
  reason      String?
  status      RequestStatus @default(PENDING)
  reviewedBy  String?  @db.Uuid
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("access_requests")
}

// Core Domain - Projects
model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String
  description String?
  ownerId     String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generatedDocuments    GeneratedDocument[]
  storyRecommendations  StoryRecommendation[]
  epics                 Epic[]
  designDoc             ProjectDesignDoc?
  stories               ProjectStory[]
  notes                 ProjectNote[]
  members               ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid @map("projectId")
  userId    String   @db.Uuid @map("userId")
  addedBy   String   @db.Uuid @map("addedBy")
  createdAt DateTime @default(now()) @map("createdAt")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

// Project Design Document
model ProjectDesignDoc {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @unique @db.Uuid @map("project_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_design_docs")
}

// Project Generated Stories
model ProjectStory {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @db.Uuid @map("project_id")
  title               String
  description         String   @db.Text
  acceptanceCriteria  String[] @map("acceptance_criteria")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_stories")
}

// Project Notes
model ProjectNote {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid @map("project_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_notes")
}

// Documentation - Topics (Wiki - Top Level)
// The wiki is strictly per-user and never shared. Ownership lives here; Subject
// and ContentItem inherit it through topicId / subjectId.
model Topic {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  title       String
  slug        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects    Subject[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("topics")
}

// Wiki - Subjects (belong to topics)
model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  topicId     String   @db.Uuid
  title       String
  slug        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic         Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  contentItems  ContentItem[]

  @@unique([slug, topicId])
  @@index([topicId])
  @@map("subjects")
}

// Wiki - Content Items (belong to subjects, optional title)
model ContentItem {
  id          String   @id @default(uuid()) @db.Uuid
  subjectId   String   @db.Uuid
  title       String?
  content     String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@map("content_items")
}

// ...existing code...

// Links Management
model LinkGroup {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  name        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  links       Link[]

  @@index([userId])
  @@map("link_groups")
}

model Link {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @db.Uuid
  title     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group     LinkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("links")
}

// Chat - Conversations & Messages
model ChatConversation {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id                  String   @id @default(uuid()) @db.Uuid
  conversationId      String   @db.Uuid
  userId              String   @db.Uuid
  content             String   @db.Text
  role                String   @default("user")
  contextDocumentIds  String[]
  tokens              Int?
  model               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  conversation        ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
  @@map("chat_messages")
}

// AI Generator - Design Documents
model GeneratedDocument {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @db.Uuid
  userId        String   @db.Uuid
  title         String
  templateType  String
  content       String   @db.Text
  sections      Json     @default("[]")
  status        String   @default("draft")
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("generated_documents")
}

// Azure DevOps - Story Recommendations
model StoryRecommendation {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  projectId         String?  @db.Uuid
  storyId           String
  title             String
  currentSize       Int?
  recommendedSize   String
  confidence        Float
  reasoning         String   @db.Text
  recommendation    String   @db.Text
  tags              String[]
  accepted          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([storyId])
  @@index([userId])
  @@index([projectId])
  @@index([accepted])
  @@map("story_recommendations")
}

// Legacy Models - Epic & Story (keeping for backward compatibility)
model Epic {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  title       String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories     Story[]

  @@map("epics")
}

model Story {
  id                  String   @id @default(uuid()) @db.Uuid
  epicId              String   @db.Uuid
  title               String
  description         String?
  acceptanceCriteria  String[]
  storyPoints         Float
  status              String   @default("todo")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  epic                Epic     @relation(fields: [epicId], references: [id], onDelete: Cascade)

  @@map("stories")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
